@model MiProyecto.Application.Common.Models.AvisoPdfDto
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <style>
        /* RESET & BASE */
        body { font-family: 'Helvetica', 'Arial', sans-serif; font-size: 11pt; color: #333; margin: 0; padding: 0; line-height: 1.5; }
        .page { padding: 40px; position: relative; min-height: 1000px; }
        
        /* HEADER CORPORATIVO */
        .header { display: flex; justify-content: space-between; align-items: center; border-bottom: 4px solid #004a99; padding-bottom: 10px; margin-bottom: 30px; }
        .logo-box { width: 180px; height: 60px; background: #004a99; color: white; display: flex; align-items: center; justify-content: center; font-weight: bold; border-radius: 4px; }
        .doc-info { text-align: right; }
        .doc-title { font-size: 22pt; font-weight: bold; color: #004a99; margin: 0; }
        
        /* BLOQUE CLIENTE (ESTILO BOOTSTRAP CARD) */
        .card { border: 1px solid #dee2e6; border-radius: 8px; padding: 20px; background-color: #f8f9fa; margin-bottom: 30px; }
        .card-title { font-size: 10pt; text-transform: uppercase; color: #666; font-weight: bold; margin-bottom: 10px; border-bottom: 1px solid #ddd; }
        
        /* TABLA DE CUOTAS (ESTILO BOOTSTRAP STRIPED) */
        .table { width: 100%; border-collapse: collapse; margin-top: 10px; }
        .table th { background-color: #004a99; color: white; padding: 12px; text-align: left; font-size: 10pt; }
        .table td { padding: 10px; border-bottom: 1px solid #dee2e6; font-size: 10pt; }
        .table tr:nth-child(even) { background-color: #f2f7fc; }
        
        /* INFORMACIÓN ADICIONAL */
        .alert-info { background-color: #e7f3ff; border-left: 5px solid #004a99; padding: 15px; margin-top: 30px; font-size: 9pt; color: #444; }
        
        /* FOOTER DECORATIVO */
        .footer { position: absolute; bottom: 0; left: 0; width: 100%; border-top: 1px solid #eee; padding-top: 20px; }
        .footer-stripe { background: linear-gradient(90deg, #004a99 0%, #3498db 100%); height: 40px; margin-top: 10px; }
        .footer-text { font-size: 8pt; color: #999; text-align: center; }
        
        /* UTILIDADES */
        .text-blue { color: #004a99; }
        .text-bold { font-weight: bold; }
        .text-end { text-align: right; }
    </style>
</head>
<body>
    <div class="page">
        <!-- HEADER -->
        <div class="header">
            <div class="logo-box">
                MI LOGO EMPRESA
            </div>
            <div class="doc-info">
                <h1 class="doc-title">AVISO DE COBRANZA</h1>
                <p>Nro. Documento: <span class="text-bold">@Model.NumeroAviso</span></p>
            </div>
        </div>

        <!-- DATOS DEL CLIENTE -->
        <div class="card">
            <div class="card-title">Información del Cliente</div>
            <div style="display: flex; justify-content: space-between;">
                <div>
                    <p><strong>Nombre:</strong> @Model.NombreCliente</p>
                    <p><strong>RUT:</strong> @Model.RutCliente</p>
                </div>
                <div class="text-end">
                    <p><strong>Póliza Asociada:</strong> @Model.NumeroPoliza</p>
                    <p><strong>Fecha Emisión:</strong> @Model.FechaEmision.ToString("dd/MM/yyyy HH:mm")</p>
                </div>
            </div>
        </div>

        <!-- TABLA DE DETALLES -->
        <table class="table">
            <thead>
                <tr>
                    <th>Descripción de Cuota</th>
                    <th>Vencimiento</th>
                    <th class="text-end">Monto Total</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var cuota in Model.Cuotas)
                {
                    <tr>
                        <td>Cuota Número @cuota.Numero</td>
                        <td>@cuota.Vencimiento.ToString("dd/MM/yyyy")</td>
                        <td class="text-end">@cuota.Monto.ToString("C0")</td>
                    </tr>
                }
            </tbody>
        </table>

        <!-- RESUMEN -->
        <div class="text-end" style="margin-top: 20px;">
            <p style="font-size: 14pt;">TOTAL A PAGAR: <span class="text-blue text-bold">@Model.TotalPagar.ToString("C0")</span></p>
        </div>

        <!-- TEXTO INFORMATIVO (SIMULAR PESO) -->
        <div class="alert-info">
            <strong>Información Importante:</strong><br />
            Este documento constituye un aviso formal de cobranza. Le recordamos que el pago oportuno de sus cuotas evita la suspensión de las coberturas asociadas a su póliza. Puede realizar su pago a través de nuestro portal web o en cualquier sucursal autorizada. Para consultas, contáctenos al 600 XXX XXXX.
        </div>

        <!-- FOOTER -->
        <div class="footer">
            <p class="footer-text">Generado automáticamente por Sistema de Biblioteca API - @DateTime.Now.Year © Todos los derechos reservados.</p>
            <div class="footer-stripe"></div>
        </div>
    </div>
</body>
</html>
